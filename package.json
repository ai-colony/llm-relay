{
  "name": "llm-relay",
  "version": "1.5.0",
  "private": true,
  "description": "HTTP relay server that queues LLM prompts against OpenAI-compatible APIs with SQLite persistence and async callback delivery",
  "main": "dist/index.js",
  "type": "module",
  "engines": {
    "node": "24 || 26",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "nodemon --exec tsx ./src/index.ts | ./node_modules/.bin/pino-pretty -i time,host,pid,traceId,sessionId,userId -S",
    "dev-raw": "nodemon --exec tsx ./src/index.ts",
    "start": "node --no-warnings=ExperimentalWarning dist/index.js",
    "run": "tsx ./src/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format:check": "prettier --check .",
    "format:fix": "prettier --write . | grep -v 'unchanged' | sed G",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "fix": "npm run format:fix && npm run lint:fix && npm run format:fix",
    "all": "npm run fix && npm run typecheck && npm run build && npm run test",
    "npm:reinstall": "rm -rf ./node_modules && rm -f ./package-lock.json && npm i && npm i",
    "drizzle:push": "npx drizzle-kit push",
    "drizzle:generate": "npx drizzle-kit generate",
    "drizzle:migrate": "npx drizzle-kit migrate",
    "docker:build": "docker build --force-rm -t llm-relay:$npm_package_version .",
    "docker:run": "docker run --rm --env-file .env.docker --name llm-relay-$npm_package_version --network=host -v llm-relay-data:/app/data llm-relay:$npm_package_version",
    "docker:it": "docker run -it --rm --env-file .env.docker --name llm-relay-$npm_package_version -v llm-relay-data:/app/data llm-relay:$npm_package_version /bin/bash"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ai-colony/llm-relay.git"
  },
  "keywords": [
    "llm",
    "relay",
    "queue",
    "openai",
    "sqlite",
    "hono",
    "typescript"
  ],
  "author": {
    "name": "BCsabaEngine",
    "url": "https://github.com/BCsabaEngine"
  },
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/ai-colony/llm-relay/issues"
  },
  "homepage": "https://github.com/ai-colony/llm-relay#readme",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "drizzle-kit": "^1.0.0-beta.22",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "eslint-plugin-unicorn": "^68.0.0",
    "globals": "^17.7.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/structured-logger": "^0.1.0",
    "@hono/zod-validator": "^0.8.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^1.0.0-beta.22",
    "env-var": "^7.5.0",
    "hono": "^4.12.27",
    "openai": "^6.44.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  }
}
