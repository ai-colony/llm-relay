# Port the HTTP server listens on.
PORT=3000

# Log verbosity: trace | debug | info | warn | error | fatal
LOG_LEVEL=info

# Path to the SQLite database file.
DATABASE_FILENAME=database.sqlite

# OpenAI-compatible upstream: base URL, model name (empty = first available),
# API key, per-request timeout in milliseconds, and max transient retry attempts
# before a prompt is permanently failed with statusError "max_retries_exceeded".
OPENAI_URL=http://localhost:8080/v1
OPENAI_MODEL=
OPENAI_KEY=none
OPENAI_TIMEOUT=10000
OPENAI_MAX_RETRY_COUNT=10

# Number of prompts processed concurrently per worker tick (1–16, default 1).
WORKER_CONCURRENCY=1

# Optional. When set, all /prompt endpoints require
# "Authorization: Bearer <API_KEY>". /health, /status, and /metrics remain public.
API_KEY=

# Optional regex allowlist for callbackUrl. Leave empty to allow any valid URL.
# When set, only URLs matching this pattern are accepted. An invalid regex crashes
# the server on startup. Use this to prevent SSRF in untrusted deployments.
# Example: ^https://my-service\.example\.com/
CALLBACK_URL_ALLOWLIST=

# How long (in hours) to keep retrying a failed callback delivery.
# After this TTL elapses since prompt completion, delivery is silently abandoned (default 24).
CALLBACK_RETRY_TTL_HOURS=24

# Optional. When set, each callback POST includes an X-LLM-Relay-Signature header
# with value "hmac-sha256=<hex>" so receivers can verify the request origin.
CALLBACK_HMAC_SECRET=

